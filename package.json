{
  "name": "dailyos",
  "version": "1.0.10",
  "description": "Ton assistant de productivité personnel",
  "main": ".vite/build/index.js",
  "author": {
    "name": "Killian Pasche",
    "email": "killian.pasche7@gmail.com"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-forge start",
    "dev": "electron-forge start",
    "postinstall": "electron-rebuild",
    "build:mac": "electron-forge make --platform darwin",
    "build:win": "electron-forge make --platform win32",
    "build:linux": "electron-forge make --platform linux",
    "publish": "electron-forge publish",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@excalidraw/excalidraw": "^0.18.1",
    "@excalimath/core": "^1.1.2",
    "@types/react-grid-layout": "^1.3.6",
    "@uiw/codemirror-themes": "^4.25.9",
    "@uiw/react-codemirror": "^4.25.9",
    "better-sqlite3": "^12.9.0",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.3.9",
    "lucide-react": "^1.14.0",
    "react-grid-layout": "^2.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.8.10",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
